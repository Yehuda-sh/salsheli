rules_version = '2';

// Storage Rules for MemoZap
// Last Updated: 27/04/2026

service firebase.storage {
  match /b/{bucket}/o {

    // === Helper Functions ===
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // בדיקה אם המשתמש חבר במשק בית
    // Note: this performs a Firestore lookup per Storage operation
    // — counts as a Firestore read against quota.
    function isHouseholdMember(householdId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    // בדיקה אם הקובץ הוא תמונה תקינה (עד 5MB)
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 5 * 1024 * 1024;
    }

    // בדיקה אם הקובץ PDF תקין (עד 10MB)
    function isValidPdf() {
      return request.resource.contentType == 'application/pdf'
             && request.resource.size < 10 * 1024 * 1024;
    }

    // === User Profile Images ===
    // Path: /users/{userId}/profile/avatar.<ext>
    //
    // Filename pinned to `avatar` (any image extension) to match what
    // image_upload_service writes — prevents an authenticated user from
    // filling their own profile/ folder with arbitrary file names.
    match /users/{userId}/profile/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId)
                   && isValidImage()
                   && fileName.matches('avatar\\.(jpg|jpeg|png|webp)');
    }

    // === Receipt Images (reserved — not yet wired in code) ===
    // Path: /households/{householdId}/receipts/{receiptId}/<file>
    //
    // The Receipt model already carries a `fileUrl` field for the
    // future "scan-to-cloud" flow. No upload service writes here yet,
    // but the rule is in place so when the feature lands we don't ship
    // an open-write window.
    match /households/{householdId}/receipts/{receiptId}/{fileName} {
      allow read: if isHouseholdMember(householdId);
      allow write: if isHouseholdMember(householdId)
                   && (isValidImage() || isValidPdf());
    }

    // === Default Deny ===
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
