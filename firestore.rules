rules_version = '2';

// 🔒 MemoZap Firestore Security Rules
//
// Version: 4.1 (March 2026)
//
// ✅ Strict Schema Validation & Audit Trail
// 📅 Last Updated: March 2026
//
// ✨ Features:
//     - Strict Schema Validation (inventory, notifications)
//     - Audit Trail enforcement (last_updated_by on inventory changes)
//     - Anti-spam protection (notification type enum, message length)
//     - isOwnerOrAdmin helper for cleaner permission checks
//
// 📅 History:
//     v4.0 (22/02/2026) — Schema validation, Audit Trail, anti-spam, helper functions
//     v3.0 (14/12/2025) — Nested Subcollections, Map-Based permissions
//
// 🏗️ Database Structure:
//
//    users/{userId}/
//    ├── private_lists/{listId}      ← רשימות פרטיות
//    ├── notifications/{notifId}
//    ├── pending_invites/{inviteId}
//    └── saved_contacts/{contactId}
//
//    households/{householdId}/
//    ├── info                        ← מידע על משק הבית
//    ├── members/{memberId}
//    ├── inventory/{itemId}          ← מלאי משותף
//    ├── receipts/{receiptId}        ← קבלות
//    ├── shared_lists/{listId}       ← רשימות משותפות
//    ├── invites/{inviteId}
//    └── join_requests/{requestId}
//
// 📄 מערכת הרשאות לרשימות משותפות (Map-Based):
//    במקום מערך, משתמשים במפה: shared_users = { "uid": { role: "..." } }
//    זה מאפשר בדיקות מהירות (O(1)) ותמיכה באינסוף משתמשים.
//
// 🎭 תפקידים:
//    1️⃣ Owner (created_by): הכל כולל מחיקת הרשימה.
//    2️⃣ Admin (role='admin'): עריכה מלאה וניהול משתמשים (ללא מחיקת רשימה).
//    3️⃣ Editor (role='editor'): עריכת מוצרים בלבד.
//    4️⃣ Viewer (role='viewer'): צפייה בלבד.

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 🛠️ Helper Functions
    // =========================================================

    // בדיקה בסיסית - האם המשתמש מחובר?
    function isAuthenticated() {
      return request.auth != null;
    }

    // בדיקה אם המשתמש הוא הבעלים של מסמך אישי
    function isDocOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // שליפת ה-Household ID של המשתמש הנוכחי
    function getUserHouseholdId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.household_id;
    }

    // בדיקה אם המשתמש שייך ל-Household ספציפי
    function isHouseholdMember(householdId) {
      return isAuthenticated() &&
             getUserHouseholdId() == householdId;
    }

    // =========================================================
    // 🆕 v4.0: Validation Helper Functions
    // =========================================================

    // בדיקה שערך הוא Timestamp תקין
    function isValidTimestamp(value) {
      return value is timestamp;
    }

    // בדיקה מקוצרת: האם המשתמש הוא Owner או Admin ברשימה
    function isOwnerOrAdmin(listData) {
      let role = getListRole(listData);
      return role == 'owner' || role == 'admin';
    }

    // בדיקה שבעדכון קיימים שדות Audit Trail תקינים
    // updated_at חייב להיות Timestamp, last_updated_by חייב להתאים ל-UID
    function hasRequiredAuditFields() {
      return isValidTimestamp(request.resource.data.updated_at) &&
             request.resource.data.last_updated_by == request.auth.uid;
    }

    // ולידציית סכימה למזווה — שדות חובה עם ערכים תקינים
    function isValidInventoryData(data) {
      return data.product_name is string &&
             data.product_name.size() >= 2 &&
             data.quantity is number &&
             data.quantity >= 0 &&
             data.min_quantity is number &&
             data.min_quantity >= 0;
    }

    // בדיקה שסוג ההתראה נמצא ברשימת ה-Enums המותרת
    function isValidNotificationType(type) {
      return type in [
        'invite', 'request_approved', 'request_rejected',
        'role_changed', 'user_removed', 'who_brings_volunteer',
        'new_vote', 'vote_tie', 'member_left', 'low_stock'
      ];
    }

    // =========================================================
    // 🔐 List Permissions Logic (Map Based 🗺️)
    // =========================================================

    // פונקציה שמחזירה את התפקיד של המשתמש ברשימה
    function getListRole(listData) {
      return listData.created_by == request.auth.uid
             ? 'owner'
             : (
                 listData.shared_users != null &&
                 request.auth.uid in listData.shared_users
                 ? listData.shared_users[request.auth.uid].role
                 : null
               );
    }

    // פונקציה לבדיקה אם למשתמש יש גישה לקבוצה
    function isGroupMember(groupId) {
      let groupData = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return groupData.created_by == request.auth.uid ||
             (groupData.members != null && request.auth.uid in groupData.members) ||
             userHasGroupInList(groupId);
    }

    // פונקציה לבדיקה אם למשתמש יש גישה לקבוצה דרך group_ids שלו
    function userHasGroupInList(groupId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // group_ids הוא array, לכן משתמשים ב-hasAny עם array של פריט אחד
      return userData.group_ids != null && userData.group_ids.hasAny([groupId]);
    }

    // =========================================================
    // 👤 Users Collection & Subcollections
    // =========================================================

    // === User Profile ===
    match /users/{userId} {
      // קריאה: רק הבעלים יכול לקרוא את הפרופיל המלא שלו
      // משתמשים אחרים יכולים לקרוא רק אם הם באותו משק בית או קבוצה
      allow read: if isDocOwner(userId) ||
                  (isAuthenticated() && getUserHouseholdId() != null &&
                   getUserHouseholdId() == get(/databases/$(database)/documents/users/$(userId)).data.household_id);
      allow write: if isDocOwner(userId);

      // === Private Lists (Subcollection) ===
      // Path: /users/{userId}/private_lists/{listId}
      match /private_lists/{listId} {

        // 👁️ קריאה: רק הבעלים של הרשימה
        allow read: if isDocOwner(userId);

        // ➕ יצירה: רק הבעלים יכול ליצור רשימות פרטיות
        allow create: if isDocOwner(userId) &&
                      request.resource.data.created_by == request.auth.uid;

        // ✏️ עדכון: רק הבעלים יכול לערוך רשימות פרטיות
        allow update: if isDocOwner(userId);

        // 🗑️ מחיקה: רק הבעלים יכול למחוק
        allow delete: if isDocOwner(userId);
      }

      // === 🔒 Notifications (Subcollection) — v4.0 Hardened ===
      // Path: /users/{userId}/notifications/{notificationId}
      // ⚠️ NOTE: Rate limiting should be implemented via Cloud Functions
      //    to prevent spam/abuse. Firestore rules cannot enforce rate limits.
      match /notifications/{notificationId} {
        // קריאה ומחיקה: רק הבעלים
        allow read, delete: if isDocOwner(userId);

        // עדכון: רק הבעלים (mark as read)
        allow update: if isDocOwner(userId);

        // ➕ יצירה: v4.0 — ולידציה מלאה
        // 1. sender_id חייב להתאים ל-UID (מניעת התחזות)
        // 2. sender_id != userId (מניעת spam לעצמך)
        // 3. user_id חייב להתאים לנתיב (data consistency)
        // 4. type חייב להיות מתוך רשימת Enums מותרת
        // 5. message מוגבל ל-500 תווים
        allow create: if isAuthenticated() &&
                      request.resource.data.sender_id == request.auth.uid &&
                      request.resource.data.sender_id != userId &&
                      request.resource.data.user_id == userId &&
                      isValidNotificationType(request.resource.data.type) &&
                      request.resource.data.message is string &&
                      request.resource.data.message.size() <= 500;
      }

      // === Pending Invites (Subcollection) ===
      // Path: /users/{userId}/pending_invites/{inviteId}
      match /pending_invites/{inviteId} {
        allow read, write: if isDocOwner(userId);
      }

      // === Saved Contacts (Subcollection) ===
      // Path: /users/{userId}/saved_contacts/{contactId}
      match /saved_contacts/{contactId} {
        allow read, write: if isDocOwner(userId);
      }

      // === 🔒 User Inventory (Subcollection) — v4.0 Schema Validated ===
      // Path: /users/{userId}/inventory/{itemId}
      // מזווה אישי - למשתמשים ללא קבוצת משפחה
      match /inventory/{itemId} {
        allow read: if isDocOwner(userId);

        // ➕ יצירה: ולידציית סכימה + audit trail
        allow create: if isDocOwner(userId) &&
                      isValidInventoryData(request.resource.data) &&
                      request.resource.data.last_updated_by == request.auth.uid;

        // ✏️ עדכון: ולידציית סכימה + חובת audit trail בשינוי כמות
        allow update: if isDocOwner(userId) &&
                      isValidInventoryData(request.resource.data) &&
                      (request.resource.data.quantity == resource.data.quantity ||
                       request.resource.data.last_updated_by == request.auth.uid);

        // 🗑️ מחיקה: רק הבעלים
        allow delete: if isDocOwner(userId);
      }
    }

    // =========================================================
    // 🏠 Households Collection & Subcollections
    // =========================================================

    // === Household Info ===
    match /households/{householdId} {
      // קריאה: רק חברי משק הבית
      allow read: if isHouseholdMember(householdId);

      // יצירה: כל משתמש מחובר יכול ליצור משק בית
      allow create: if isAuthenticated();

      // עדכון: רק חברי משק הבית
      allow update: if isHouseholdMember(householdId);

      // מחיקה: לא מאפשרים (למנוע אובדן נתונים)
      allow delete: if false;

      // === Shared Lists (Subcollection) ===
      // Path: /households/{householdId}/shared_lists/{listId}
      match /shared_lists/{listId} {

        // 👁️ קריאה: חברי משק הבית או מי שמשותף ברשימה
        allow read: if isAuthenticated() && (
          isHouseholdMember(householdId) ||
          (resource.data.shared_users != null && request.auth.uid in resource.data.shared_users)
        );

        // ➕ יצירה: חבר משק הבית (חובה להגדיר created_by)
        allow create: if isHouseholdMember(householdId) &&
                      request.resource.data.created_by == request.auth.uid;

        // ✏️ עדכון: לוגיקה מפוצלת לפי תפקידים
        allow update: if isAuthenticated() && (

          // 1. Owner: יכול לעשות הכל
          getListRole(resource.data) == 'owner' ||

          // 2. Admin: יכול לערוך הכל חוץ מלשנות את הבעלים
          (getListRole(resource.data) == 'admin' &&
           request.resource.data.created_by == resource.data.created_by) ||

          // 3. Editor: יכול לערוך רק items, updated_date, ושדות audit
          // 🔒 v4.0: affectedKeys().hasOnly() מבטיח ש-Editor לא יכול לשנות
          //    את שם הרשימה, הבעלים, shared_users, או כל שדה אחר
          (getListRole(resource.data) == 'editor' &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['items', 'updated_date', 'updated_at', 'last_updated_by']))

          // 4. Viewer: צפייה בלבד - לא יכול לעדכן (אין צורך בכלל כאן)
        );

        // 🗑️ מחיקה: רק הבעלים המקורי
        allow delete: if isAuthenticated() &&
                      resource.data.created_by == request.auth.uid;
      }

      // === 🔒 Household Inventory (Subcollection) — v4.0 Schema Validated ===
      // Path: /households/{householdId}/inventory/{itemId}
      match /inventory/{itemId} {
        allow read: if isHouseholdMember(householdId);

        // ➕ יצירה: ולידציית סכימה + audit trail
        allow create: if isHouseholdMember(householdId) &&
                      isValidInventoryData(request.resource.data) &&
                      request.resource.data.last_updated_by == request.auth.uid;

        // ✏️ עדכון: ולידציית סכימה + חובת audit trail בשינוי כמות
        allow update: if isHouseholdMember(householdId) &&
                      isValidInventoryData(request.resource.data) &&
                      (request.resource.data.quantity == resource.data.quantity ||
                       request.resource.data.last_updated_by == request.auth.uid);

        // 🗑️ מחיקה: רק חברי משק הבית (מניעת מחיקה שרירותית — שקול soft-delete)
        allow delete: if isHouseholdMember(householdId);
      }

      // === Receipts (Subcollection) ===
      // Path: /households/{householdId}/receipts/{receiptId}
      match /receipts/{receiptId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // === Members (Subcollection) ===
      // Path: /households/{householdId}/members/{memberId}
      match /members/{memberId} {
        allow read: if isHouseholdMember(householdId);

        // יצירה: רק אם המשתמש מוסיף את עצמו (הצטרפות למשק בית)
        allow create: if isAuthenticated() && memberId == request.auth.uid;

        // עדכון: חבר יכול לעדכן רק את עצמו, או admin יכול לעדכן אחרים
        allow update: if isHouseholdMember(householdId) && (
          memberId == request.auth.uid ||
          get(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data.role == 'admin'
        );

        // מחיקה: חבר יכול להסיר את עצמו, או admin יכול להסיר אחרים (לא את עצמו)
        allow delete: if isHouseholdMember(householdId) && (
          memberId == request.auth.uid ||
          (get(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data.role == 'admin' &&
           memberId != request.auth.uid)
        );
      }

      // === Invites (Subcollection) ===
      // Path: /households/{householdId}/invites/{inviteId}
      match /invites/{inviteId} {
        // קריאה: חברי משק הבית או מי שהוזמן
        allow read: if isAuthenticated() && (
          isHouseholdMember(householdId) ||
          resource.data.invited_user_id == request.auth.uid
        );
        // כתיבה: חברי משק הבית
        allow write: if isHouseholdMember(householdId);
      }

      // === Join Requests (Subcollection) ===
      // Path: /households/{householdId}/join_requests/{requestId}
      match /join_requests/{requestId} {
        // קריאה: חברי משק הבית או מי שביקש להצטרף
        allow read: if isAuthenticated() && (
          isHouseholdMember(householdId) ||
          resource.data.requester_id == request.auth.uid
        );
        // יצירה: כל משתמש מחובר יכול לבקש להצטרף
        allow create: if isAuthenticated() &&
                      request.resource.data.requester_id == request.auth.uid;
        // עדכון/מחיקה: חברי משק הבית (לאשר/לדחות בקשות)
        allow update, delete: if isHouseholdMember(householdId);
      }
    }

    // =========================================================
    // 👥 Groups Collection
    // =========================================================

    match /groups/{groupId} {
      // 👁️ קריאה: חברי הקבוצה או מי שיש לו את הקבוצה ב-group_ids
      allow read: if isAuthenticated() && isGroupMember(groupId);

      // ➕ יצירה: כל משתמש מחובר יכול ליצור קבוצה
      allow create: if isAuthenticated() &&
                    request.resource.data.created_by == request.auth.uid;

      // ✏️ עדכון: חברי הקבוצה בלבד
      allow update: if isAuthenticated() && isGroupMember(groupId);

      // 🗑️ מחיקה: רק היוצר
      allow delete: if isAuthenticated() &&
                    resource.data.created_by == request.auth.uid;

      // === 🔒 Group Inventory (Subcollection) — v4.0 Schema Validated ===
      // Path: /groups/{groupId}/inventory/{itemId}
      // מזווה קבוצתי - לקבוצות משפחה/שותפים
      match /inventory/{itemId} {
        allow read: if isAuthenticated() && isGroupMember(groupId);

        // ➕ יצירה: ולידציית סכימה + audit trail
        allow create: if isAuthenticated() && isGroupMember(groupId) &&
                      isValidInventoryData(request.resource.data) &&
                      request.resource.data.last_updated_by == request.auth.uid;

        // ✏️ עדכון: ולידציית סכימה + חובת audit trail בשינוי כמות
        allow update: if isAuthenticated() && isGroupMember(groupId) &&
                      isValidInventoryData(request.resource.data) &&
                      (request.resource.data.quantity == resource.data.quantity ||
                       request.resource.data.last_updated_by == request.auth.uid);

        // 🗑️ מחיקה: חברי הקבוצה בלבד
        allow delete: if isAuthenticated() && isGroupMember(groupId);
      }
    }

    // =========================================================
    // 📦 Global Collections
    // =========================================================

    // === Products (Global Catalog) ===
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // =========================================================
    // 📋 Templates Collection
    // =========================================================
    // תבניות רשימות קניות מוכנות
    // סוגים:
    //   1. System templates (is_system=true): קריאה לכולם, כתיבה רק admin
    //   2. User templates (user_id): פרטיות למשתמש
    //   3. Household templates (household_id): משותפות למשק בית

    match /templates/{templateId} {
      // 👁️ קריאה:
      // - תבניות מערכת: כולם (גם לא מחוברים - לטובת UX)
      // - תבניות משתמש: רק הבעלים
      // - תבניות משק בית: חברי משק הבית
      allow read: if resource.data.is_system == true ||
                  (isAuthenticated() && (
                    resource.data.user_id == request.auth.uid ||
                    (resource.data.household_id != null && isHouseholdMember(resource.data.household_id))
                  ));

      // ➕ יצירה: משתמש מחובר יכול ליצור תבנית פרטית או למשק בית שלו
      // אסור ליצור תבניות מערכת (is_system=true) מהקליינט
      allow create: if isAuthenticated() &&
                    request.resource.data.is_system != true &&
                    request.resource.data.created_by == request.auth.uid &&
                    (
                      request.resource.data.user_id == request.auth.uid ||
                      (request.resource.data.household_id != null && isHouseholdMember(request.resource.data.household_id))
                    );

      // ✏️ עדכון: רק הבעלים או חבר משק הבית (לא תבניות מערכת)
      allow update: if isAuthenticated() &&
                    resource.data.is_system != true &&
                    (
                      resource.data.user_id == request.auth.uid ||
                      (resource.data.household_id != null && isHouseholdMember(resource.data.household_id))
                    );

      // 🗑️ מחיקה: רק היוצר (לא תבניות מערכת)
      allow delete: if isAuthenticated() &&
                    resource.data.is_system != true &&
                    resource.data.created_by == request.auth.uid;
    }

    // =========================================================
    // 📍 Custom Locations Collection — v4.0 Enforced Ownership
    // =========================================================
    // מיקומי אחסון מותאמים אישית (מקרר, מזווה וכו')
    // מסוננים לפי household_id או group_id

    match /custom_locations/{locationId} {
      // 👁️ קריאה: חברי משק הבית או הקבוצה
      allow read: if isAuthenticated() && (
        // לפי household_id
        (resource.data.household_id != null && isHouseholdMember(resource.data.household_id)) ||
        // לפי group_id
        (resource.data.group_id != null && userHasGroupInList(resource.data.group_id))
      );

      // ➕ יצירה: v4.0 — אכיפת השתייכות + created_by
      // household_id/group_id חייבים להתאים להשתייכות המשתמש בפועל
      allow create: if isAuthenticated() &&
                    request.resource.data.created_by == request.auth.uid &&
                    (
                      (request.resource.data.household_id != null && isHouseholdMember(request.resource.data.household_id)) ||
                      (request.resource.data.group_id != null && userHasGroupInList(request.resource.data.group_id))
                    );

      // ✏️ עדכון: חברי משק הבית או קבוצה
      allow update: if isAuthenticated() && (
        (resource.data.household_id != null && isHouseholdMember(resource.data.household_id)) ||
        (resource.data.group_id != null && userHasGroupInList(resource.data.group_id))
      );

      // 🗑️ מחיקה: חברי משק הבית או קבוצה
      allow delete: if isAuthenticated() && (
        (resource.data.household_id != null && isHouseholdMember(resource.data.household_id)) ||
        (resource.data.group_id != null && userHasGroupInList(resource.data.group_id))
      );
    }

    // =========================================================
    // 📨 Group Invites Collection
    // =========================================================

    // פונקציה לבדיקה אם המשתמש הוא המוזמן
    function isInvitedUser(inviteData) {
      // בדיקה לפי טלפון או אימייל מה-token
      let byPhone = request.auth.token.phone_number != null &&
                    inviteData.invited_phone == request.auth.token.phone_number;
      let byEmail = request.auth.token.email != null &&
                    inviteData.invited_email == request.auth.token.email;
      // בדיקה לפי invited_user_id אם קיים
      let byUserId = inviteData.invited_user_id != null &&
                     inviteData.invited_user_id == request.auth.uid;
      return byPhone || byEmail || byUserId;
    }

    match /group_invites/{inviteId} {
      // 👁️ קריאה:
      // - המזמין יכול לראות הזמנות שהוא שלח
      // - המוזמן יכול לראות הזמנות שנשלחו אליו (לפי טלפון/אימייל/userId)
      // - כל משתמש מחובר יכול לחפש הזמנות (ה-query יסנן)
      allow read: if isAuthenticated();

      // ➕ יצירה: כל משתמש מחובר יכול ליצור הזמנה
      allow create: if isAuthenticated() &&
                    request.resource.data.invited_by == request.auth.uid;

      // ✏️ עדכון: המזמין או המוזמן יכול לעדכן
      allow update: if isAuthenticated() && (
        resource.data.invited_by == request.auth.uid ||
        isInvitedUser(resource.data)
      );

      // 🗑️ מחיקה: רק המזמין
      allow delete: if isAuthenticated() &&
                    resource.data.invited_by == request.auth.uid;
    }

    // =========================================================
    // 🚫 Legacy Collections (Migration in progress)
    // =========================================================
    // ⚠️ קולקציות ישנות — קריאה בלבד עד סיום המיגרציה.
    //    לאחר סיום המיגרציה המלאה, יש למחוק בלוק זה לגמרי.
    //    כל הנתונים החדשים נכתבים ל-Subcollections (ראה מבנה למעלה).

    // === Legacy: shopping_lists ===
    match /shopping_lists/{listId} {
      allow read: if isAuthenticated() && (
        resource.data.created_by == request.auth.uid ||
        (resource.data.household_id != null && isHouseholdMember(resource.data.household_id)) ||
        (resource.data.shared_users != null && request.auth.uid in resource.data.shared_users)
      );
      allow write: if false;
    }

    // === Legacy: receipts ===
    match /receipts/{receiptId} {
      allow read: if isAuthenticated() &&
                  resource.data.household_id != null &&
                  isHouseholdMember(resource.data.household_id);
      allow write: if false;
    }

    // === Legacy: inventory ===
    match /inventory/{itemId} {
      allow read: if isAuthenticated() &&
                  resource.data.household_id != null &&
                  isHouseholdMember(resource.data.household_id);
      allow write: if false;
    }

    // === Legacy: notifications ===
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                  resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // =========================================================
    // 🔒 Default Deny
    // =========================================================

    // חסימת כל השאר
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
